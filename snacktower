#include <bits/stdc++.h>
using namespace std;

#define vi vector<int>
#define pb push_back
#define ll long long
#define yes cout << "YES\n"
#define no cout << "NO\n"

void solve()
{
    int n;
    cin >> n;

    vector<int> v(n + 1);
    vector<int> vis(n + 1, 0);

    for (int i = 1; i <= n; i++)
        cin >> v[i];

    int need = n;

    for (int i = 1; i <= n; i++)
    {
        vis[v[i]] = 1;

        while (need >= 1 && vis[need])
        {
            cout << need << " ";
            need--;
        }

        cout << endl;
    }
}

int main()
{
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    solve();
}
